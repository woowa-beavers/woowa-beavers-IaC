# terraform/cloudflare/terraform.tfvars.example
# 역할: Cloudflare 모듈 변수 값 예시 (실제 사용 시 terraform.tfvars 로 복사, 절대 커밋 금지)
# 흐름: 예시 값 확인 → terraform.tfvars 생성 → terraform apply 시 variables.tf 로 주입

cloudflare_api_token = "your-cloudflare-api-token"
cloudflare_zone_id   = "your-cloudflare-zone-id"

tunnel_id_bastion       = "your-bastion-tunnel-id"
tunnel_id_thehive       = "your-thehive-tunnel-id"
tunnel_id_misp          = "your-misp-tunnel-id"
tunnel_id_n8n           = "your-n8n-tunnel-id"
tunnel_id_velociraptor  = "your-velociraptor-tunnel-id"
tunnel_id_wazuh         = "your-wazuh-tunnel-id"

shop_cname_target = "your-cloudfront-domain.cloudfront.net"
