# terraform/environments/dev/terraform.tfvars.example
# 역할: dev 루트 모듈 변수 값 예시 (실제 사용 시 terraform.tfvars 로 복사)
# 흐름: 예시 값 확인 → terraform.tfvars 생성 → terraform apply 시 variables.tf 로 주입

aws_region = "ap-northeast-2"

# Key Pairs (공개키 전체 문자열 입력 — GitHub Secrets: TF_VAR_BASTION_NAT_PUBLIC_KEY / TF_VAR_EC2_PUBLIC_KEY)
# bastion_nat_public_key = "ssh-rsa AAAA..."
# ec2_public_key         = "ssh-rsa AAAA..."

# Bastion
bastion_ami_id     = "ami-xxxxxxxxxxxxxxxxx"
bastion_key_name   = "woowa-beavers-bastion-EC2-key"
bastion_private_ip = "10.0.1.xxx"

# NAT
nat_ami_id     = "ami-xxxxxxxxxxxxxxxxx"
nat_key_name   = "woowa-beavers-bastion-EC2-key"
nat_private_ip = "10.0.1.xxx"

# EC2-1 Product
ec2_1_ami_id     = "ami-xxxxxxxxxxxxxxxxx"
ec2_1_key_name   = "woowa-beavers-keypair"
ec2_1_private_ip = "10.0.2.xxx"

# EC2-2 Auth
ec2_2_ami_id     = "ami-xxxxxxxxxxxxxxxxx"
ec2_2_key_name   = "woowa-beavers-keypair"
ec2_2_private_ip = "10.0.2.xxx"

# EC2-3 Inventory
ec2_3_ami_id     = "ami-xxxxxxxxxxxxxxxxx"
ec2_3_key_name   = "woowa-beavers-keypair"
ec2_3_private_ip = "10.0.2.xxx"

# EC2-4 Order
ec2_4_ami_id     = "ami-xxxxxxxxxxxxxxxxx"
ec2_4_key_name   = "woowa-beavers-keypair"
ec2_4_private_ip = "10.0.2.xxx"

# EC2-5 Red Team
ec2_5_ami_id     = "ami-xxxxxxxxxxxxxxxxx"
ec2_5_key_name   = "woowa-beavers-keypair"
ec2_5_private_ip = "10.0.2.xxx"

# RDS
# auth_db_password     = ""  # GitHub Secrets: TF_VAR_AUTH_DB_PASSWORD
# commerce_db_password = ""  # GitHub Secrets: TF_VAR_COMMERCE_DB_PASSWORD

# ALB
certificate_arn            = "arn:aws:acm:ap-northeast-2:xxxxxxxxxxxx:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
cloudfront_certificate_arn = "arn:aws:acm:us-east-1:xxxxxxxxxxxx:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
waf_web_acl_arn            = "arn:aws:wafv2:us-east-1:xxxxxxxxxxxx:global/webacl/CreatedByCloudFront-xxxxxxxx/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# CloudFront
# x_origin_secret = ""  # GitHub Secrets: TF_VAR_X_ORIGIN_SECRET
