# terraform/sec/terraform.tfvars.example
# 역할: sec 루트 모듈 변수 예시 (실제 값은 terraform.tfvars에 작성, gitignore 처리)
# 흐름: 이 파일 복사 → terraform.tfvars 생성 → 실제 값 입력

# Networking (MISP)
misp_vpc_name            = "soc-misp-vpc"
misp_public_subnet_name  = "soc-misp-public-subnet"
misp_private_subnet_name = "soc-misp-private-subnet"

# Compute (TheHive)
ec2_ami                   = "ami-xxxxxxxxxxxxxxxxx"
thehive_vpc_id            = "vpc-xxxxxxxxxxxxxxxxx"
thehive_public_subnet_id  = "subnet-xxxxxxxxxxxxxxxxx"
thehive_private_subnet_id = "subnet-xxxxxxxxxxxxxxxxx"
thehive_admin_cidr        = "x.x.x.x/32"
thehive_nat_eip_alloc_id  = "eipalloc-xxxxxxxxxxxxxxxxx"

# Compute (MISP)
misp_ami = "ami-xxxxxxxxxxxxxxxxx"

# Security
sec_account_id = "xxxxxxxxxxxx"
